# Firebase Auth — required for Google login.
# Copy this file to `.env` (or `.env.local`) and fill in your values.
# Find these values in: Firebase Console → Project Settings → Your apps → SDK setup.
# All vars MUST be prefixed with VITE_ so Vite exposes them to the browser bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
